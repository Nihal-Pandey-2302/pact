{
  "name": "pact",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pact — conditional settlement (the escrow scheme) for x402 agent payments on Pharos",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "facilitator": "tsx src/facilitator/server.ts",
    "provider": "tsx skills/pact-escrow/server.ts",
    "client": "tsx skills/pact-escrow/client.ts",
    "reputation": "tsx skills/pact-reputation/check.ts",
    "demo": "tsx src/demo/run.ts",
    "steward": "tsx agent/steward/demo.ts",
    "gateway": "tsx src/gateway/server.ts",
    "app": "bash scripts/start.sh",
    "app:live": "bash scripts/start.sh --live",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
